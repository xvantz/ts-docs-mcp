{
  "name": "ts-docs-mcp",
  "version": "0.3.0",
  "description": "MCP server that provides LLMs with accurate, up-to-date TypeScript API documentation directly from node_modules — no stale READMEs, no hallucinations.",
  "type": "module",
  "bin": {
    "ts-docs-mcp": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/types.js",
    "dist/types.d.ts",
    "dist/types.d.ts.map",
    "dist/registry.js",
    "dist/registry.d.ts",
    "dist/registry.d.ts.map",
    "dist/parser.js",
    "dist/parser.d.ts",
    "dist/parser.d.ts.map",
    "dist/format.js",
    "dist/format.d.ts",
    "dist/format.d.ts.map",
    "dist/cache.js",
    "dist/cache.d.ts",
    "dist/cache.d.ts.map",
    "dist/throttle.js",
    "dist/throttle.d.ts",
    "dist/throttle.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --exclude='src/**/*.int.test.ts'",
    "test:integration": "vitest run src/**/*.int.test.ts",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "documentation",
    "typedoc",
    "llm",
    "ai",
    "cursor",
    "claude-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://git.827482.xyz/xvantz/ts-docs-mcp.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  }
}
